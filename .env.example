# EDU Standalone — Entorno Python
# ================================
# Plantilla de configuración. setup.sh la copia a .env en la raíz del repo.
# El .env real es ignorado por .gitignore — nunca commitear con secretos.
#
# Uso: bash salida/edu-standalone/scripts/setup.sh
#      (genera .env automáticamente con las rutas correctas según el entorno)

# ── Python ────────────────────────────────────────────────────────────────────
PYTHON_MIN_VERSION=3.10
# Ruta al venv (relativa a la raíz del repo / módulo standalone)
VENV_PATH=.venv
# Intérprete preferido — setup.sh auto-detecta si está vacío
PYTHON_BIN=

# ── Dependencias requeridas ───────────────────────────────────────────────────
# Instalar con: pip install -r salida/edu-standalone/scripts/requirements.txt
#   google-api-python-client  >= 2.100.0
#   google-auth-oauthlib      >= 1.1.0
#   google-auth-httplib2      >= 0.1.1
#   pyyaml                    >= 6.0.1
#   requests                  >= 2.31.0
#   matplotlib                >= 3.7.0
#   Pillow                    >= 10.0.0

# ── Credenciales Google (rutas relativas a la raíz — no mover los archivos) ───
EDU_CREDENTIALS_PATH=_edu/credentials.json
EDU_TOKEN_PATH=_edu/token_slides.json
EDU_SECRETS_PATH=_edu/secrets.local.yaml

# ── Config EDU ────────────────────────────────────────────────────────────────
EDU_CONFIG_PATH=_edu/slides-config.yaml

# ── Pipeline (setup.sh sobreescribe esta línea con la ruta correcta) ──────────
# Modo embedded (repo completo):  salida/edu-standalone/scripts/slides_pipeline.py
# Modo standalone (módulo solo):  scripts/slides_pipeline.py
EDU_PIPELINE_SCRIPT=salida/edu-standalone/scripts/slides_pipeline.py
