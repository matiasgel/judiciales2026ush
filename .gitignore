# EDU Standalone — Ignorar en git
# =================================

# Credenciales y secretos OAuth (NUNCA commitear)
_edu/credentials.json
_edu/token_slides.json
_edu/token*.json
_edu/secrets.local.yaml

# Variables de entorno con rutas locales
.env

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Assets generados localmente (imágenes/tablas = artefactos, no código)
salida/cursadas/*/temas/*/slides/assets/
salida/cursadas/*/temas/*/slides/slides-url.txt

# Test runs (generados por test_pipeline.py)
reporte/

# Temas de prueba / fixtures temporales
salida/cursadas/*/temas/*prueba*/
salida/cursadas/*/temas/*pruebas*/

# Sprint 5 — Analytics (datos de alumnos)
analytics/*.csv

# Sprint 7 — Audio generado
salida/cursadas/*/temas/*/audio/

# Sprint 7 — Interactivos generados
salida/cursadas/*/temas/*/interactivos/

# Sprint 10 — Modelos ML descargados
_edu-knowledge/models/

# Sprint 11 — Knowledge Graph artifacts
_edu-knowledge/universal-kg.json

# Sprint 13 — Student state
salida/cursadas/*/students/

# IDE
.vscode/
.idea/
